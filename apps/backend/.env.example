# --------------------------------------------------
# App
# --------------------------------------------------
APP_NAME=movie-reco-backend
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

# --------------------------------------------------
# Database
# Replace with your real Postgres connection string
# Example:
# postgresql+psycopg2://username:password@localhost:5432/movie_reco
# --------------------------------------------------
DATABASE_URL=postgresql+psycopg2://movie_user:movie_password@movie-reco-db.cfos8keu44xz.ap-southeast-2.rds.amazonaws.com:5432/postgres?sslmode=require

# --------------------------------------------------
# JWT / Auth
# Change this in real environments
# --------------------------------------------------
JWT_SECRET=change-this-to-a-long-random-secret
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --------------------------------------------------
# CORS
# Comma-separated origins
# --------------------------------------------------
ALLOWED_ORIGINS=http://localhost:5173

# --------------------------------------------------
# Recommendation artifact paths
# These default to apps/backend/data/... in config.py,
# so you usually do not need to change them unless your
# files live somewhere else.
# --------------------------------------------------
CF_RECS_PATH=data/cf_top50_recommendations.csv
CONTENT_RECS_PATH=data/final_movie_recommendations_mapped.csv
MODEL_DIR=models

S3_ARTIFACTS_ENABLED=false
AWS_REGION=ap-southeast-2
S3_ARTIFACT_BUCKET=movie-reco-artifacts-tarun
S3_CF_RECS_KEY=artifacts/cf_top50_recommendations.csv
S3_CONTENT_RECS_KEY=artifacts/final_movie_recommendations_mapped.csv
S3_ARTIFACTS_ENABLED=true

# --------------------------------------------------
# Optional future LLM config
# Leave blank for now if unused
# --------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

